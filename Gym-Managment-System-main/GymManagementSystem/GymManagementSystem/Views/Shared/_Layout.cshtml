<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GYM PRO</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GymManagementSystem.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

    <style>
        :root {
            --primary-dark: #212529;
            --accent-color: #ffc107; /* Yellow Gym Style */
        }

        body { 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh; 
            background-color: #f4f7f6; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Navbar Enhancements */
        .navbar {
            padding: 0.8rem 1rem;
            transition: all 0.3s ease;
        }

        .nav-link { 
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: all 0.3s ease; 
            border-radius: 8px; 
            margin: 0 3px; 
        }

        .nav-link:hover { 
            background-color: rgba(255,193,7, 0.15); 
            color: var(--accent-color) !important; 
            transform: translateY(-2px);
        }

        .nav-link.active-link {
            background-color: var(--accent-color);
            color: #000 !important;
        }

        .navbar-brand {
            font-size: 1.5rem;
            letter-spacing: 1px;
        }

        /* Content Area */
        main { flex: 1; }

        /* Footer Styling */
        .footer { 
            background-color: #fff; 
            border-top: 3px solid var(--primary-dark);
            box-shadow: 0 -5px 15px rgba(0,0,0,0.05); 
        }

        .btn-warning {
            color: #000;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4 sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold px-3 animate__animated animate__fadeInLeft" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill text-warning"></i> GYM <span class="text-danger">PRO</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 mx-lg-3">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Memberships" asp-action="Index">
                                <i class="bi bi-card-checklist"></i> Plans
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Trainers" asp-action="Index">
                                <i class="bi bi-person-badge"></i> Trainers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Members" asp-action="Index">
                                <i class="bi bi-people"></i> Members
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="WorkoutPlans" asp-action="Index">
                                <i class="bi bi-clipboard-data"></i> Workout Plans
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="WorkSchedules" asp-action="Index">
                                <i class="bi bi-calendar-event"></i> Schedules
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-lg-3">
                            <a class="btn btn-outline-warning btn-sm fw-bold px-3 rounded-pill" asp-controller="Payments" asp-action="Index">
                                <i class="bi bi-cash-stack"></i> Finance
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-secondary small" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-lg-5">
        <main role="main" class="pb-3 animate__animated animate__fadeIn">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-3 mt-auto">
        <div class="container text-center">
            <div class="d-flex justify-content-center align-items-center gap-2">
                <span class="text-muted small">&copy; 2026 - <span class="fw-bold text-dark">GYM PRO Management</span></span>
                <span class="badge bg-warning text-dark">v2.0</span>
            </div>
            <div class="mt-2">
                <span class="badge bg-dark rounded-pill px-3 py-2">
                    <i class="bi bi-code-slash me-1 text-warning"></i> Designed by Mohamed Saber
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>