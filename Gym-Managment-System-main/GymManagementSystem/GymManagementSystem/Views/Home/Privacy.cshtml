@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3 overflow-hidden">
        @* Header بتنسيق رياضي *@
        <div class="card-header bg-dark text-white py-4 text-center">
            <h1 class="display-5 fw-bold mb-0">
                <i class="bi bi-shield-lock text-warning me-2"></i> @ViewData["Title"]
            </h1>
        </div>

        <div class="card-body p-5">
            <div class="row justify-content-center">
                <div class="col-md-10">
                    <h3 class="text-primary mb-4">Your Data is Secure</h3>
                    <p class="lead text-muted">
                        This <strong>Gym Management System</strong> has been developed as a professional management solution. 
                        We take the privacy of our members and trainers very seriously.
                    </p>

                    <hr class="my-4">

                    <div class="row mt-4">
                        <div class="col-md-6 mb-4">
                            <h5 class="fw-bold"><i class="bi bi-person-check-fill text-success me-2"></i> Member Data</h5>
                            <p>All member personal information, including names, emails, and subscription plans, is stored securely in our local database.</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <h5 class="fw-bold"><i class="bi bi-currency-dollar text-success me-2"></i> Payment Records</h5>
                            <p>Payment history and financial data are encrypted and accessible only by authorized administrators.</p>
                        </div>
                    </div>

                    <div class="alert alert-info border-0 shadow-sm mt-3">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        This system was built for educational and gym management purposes.
                    </div>

                    <div class="mt-5 text-center border-top pt-4">
                        <p class="mb-1 text-muted">System Architect & Developer</p>
                        <h4 class="text-dark fw-bold">Mohamed Saber</h4>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-5 mt-3 shadow-sm">
                            <i class="bi bi-house-door me-2"></i> Return to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>