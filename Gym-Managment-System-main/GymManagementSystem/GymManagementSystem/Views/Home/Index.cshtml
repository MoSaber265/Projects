@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* تأثير خفيف لما تعدي بالماوس على الكروت */
    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        text-decoration: none !important;
    }
    .stat-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
    }
</style>

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Welcome to <span class="text-danger">GYM PRO</span> 🏋️‍♂️</h1>
    <p class="lead text-muted">Real-time statistics for your gym management.</p>
</div>

<div class="row mt-5 g-4">
    <div class="col-md-3">
        <a asp-controller="Trainers" asp-action="Index" class="card stat-card bg-primary text-white shadow border-0 h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-person-badge fs-1"></i>
                <h4 class="mt-2">Trainers</h4>
                <h2 class="display-5 fw-bold">@ViewBag.TrainersCount</h2>
                <small class="opacity-75">View All Staff <i class="bi bi-arrow-right"></i></small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Members" asp-action="Index" class="card stat-card bg-success text-white shadow border-0 h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-people-fill fs-1"></i>
                <h4 class="mt-2">Members</h4>
                <h2 class="display-5 fw-bold">@ViewBag.MembersCount</h2>
                <small class="opacity-75">Manage Members <i class="bi bi-arrow-right"></i></small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="WorkoutPlans" asp-action="Index" class="card stat-card bg-info text-white shadow border-0 h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-card-checklist fs-1"></i>
                <h4 class="mt-2">Plans</h4>
                <h2 class="display-5 fw-bold">@ViewBag.PlansCount</h2>
                <small class="opacity-75">Workout Library <i class="bi bi-arrow-right"></i></small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Payments" asp-action="Index" class="card stat-card bg-warning text-dark shadow border-0 h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-cash-stack fs-1"></i>
                <h4 class="mt-2">Revenue</h4>
                <h2 class="display-5 fw-bold">@ViewBag.TotalRevenue.ToString("N0") <small class="fs-6 text-muted">EGP</small></h2>
                <small class="text-muted fw-bold">Financial Reports <i class="bi bi-arrow-right"></i></small>
            </div>
        </a>
    </div>
</div>

<div class="text-center mt-5">
    <div class="d-inline-flex gap-3">
        <a asp-controller="Payments" asp-action="Create" class="btn btn-dark btn-lg px-4 shadow">
            <i class="bi bi-plus-circle me-2"></i> Quick Payment
        </a>
        <a asp-controller="WorkSchedules" asp-action="Index" class="btn btn-outline-dark btn-lg px-4">
            <i class="bi bi-calendar-event me-2"></i> View Schedule
        </a>
    </div>
</div>