@model IEnumerable<GymManagementSystem.Models.WorkoutPlan>

@{
    ViewData["Title"] = "Workout Plans";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-calendar-check text-warning me-2"></i> Workout Plans
            </h5>
            <a asp-action="Create" class="btn btn-warning btn-sm fw-bold shadow-sm">
                <i class="bi bi-plus-lg"></i> Add New Plan
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Plan Name</th>
                            <th>Assigned Trainer</th>
                            <th>Difficulty</th>
                            <th>Description</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-primary">@item.PlanName</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle px-3">
                                            <i class="bi bi-person-badge me-1"></i> @(item.Trainer?.Name ?? "General Coach")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="text-nowrap">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                                    <i class="bi bi-star-fill @(i < (item.DifficultyLevel / 2) ? "text-warning" : "text-muted opacity-25")"></i>
                                        }
                                            <small class="ms-1 text-muted small">(@item.DifficultyLevel/10)</small>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted small d-inline-block text-truncate" style="max-width: 180px;" title="@item.Description">
                                        @(string.IsNullOrEmpty(item.Description) ? "No description" : item.Description)
                                        </span>
                                    </td>
                                    <td class="text-center pe-3">
                                        <div class="btn-group shadow-sm border rounded" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.PlanID" 
                                               class="btn btn-white btn-sm text-warning border-end" title="Edit Plan">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.PlanID" 
                                               class="btn btn-white btn-sm text-info border-end" title="View Exercises">
                                                <i class="bi bi-info-circle fs-5"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.PlanID" 
                                               class="btn btn-white btn-sm text-danger" title="Delete Plan">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
                <div class="card-footer bg-light text-center py-5 border-0">
                    <i class="bi bi-clipboard-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted mb-0">No workout plans available yet. Time to create some routines!</p>
                </div>
        }
    </div>
</div>