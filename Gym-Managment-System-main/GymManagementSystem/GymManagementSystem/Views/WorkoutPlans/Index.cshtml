@model IEnumerable<GymManagementSystem.Models.WorkoutPlan>

@{
    ViewData["Title"] = "Workout Plans";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-calendar-check text-primary"></i> Workout Plans</h2>
        <a asp-action="Create" class="btn btn-primary shadow">
            <i class="bi bi-plus-lg"></i> Add New Plan
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Plan Name</th>
                            <th>Assigned Trainer</th>
                            <th>Difficulty Level</th>
                            <th>Description</th>
                            <th class="text-center">Actions</th> @* عمود الأكشن *@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.PlanName</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-person-badge me-1"></i> @(item.Trainer?.Name ?? "General Coach")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="text-nowrap">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            // تعديل المعادلة عشان النجوم تظهر بدقة
                                                    <i class="bi bi-star-fill @(i < (item.DifficultyLevel / 2) ? "text-warning" : "text-muted opacity-25")"></i>
                                        }
                                            <small class="ms-1 text-muted">(@item.DifficultyLevel/10)</small>
                                        </div>
                                    </td>
                                    <td>
                                        <small class="text-muted d-inline-block text-truncate" style="max-width: 200px;">
                                        @(string.IsNullOrEmpty(item.Description) ? "No description" : item.Description)
                                        </small>
                                    </td>
                                    <td class="text-center">
                                    @* زرار الحذف اللى ربطناه بالـ PlanID *@
                                        <a asp-action="Delete" asp-route-id="@item.PlanID" class="btn btn-sm btn-outline-danger shadow-sm">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (!Model.Any())
        {
                <div class="card-footer bg-white text-center py-4">
                    <p class="text-muted mb-0">No workout plans available yet. Click "Add New Plan" to start.</p>
                </div>
        }
    </div>
</div>