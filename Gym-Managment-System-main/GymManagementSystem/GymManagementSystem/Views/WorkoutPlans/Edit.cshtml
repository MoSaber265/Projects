@model GymManagementSystem.Models.WorkoutPlan

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-info text-white py-3">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Workout Plan</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="PlanID" />

                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label asp-for="PlanName" class="form-label fw-bold"></label>
                        <input asp-for="PlanName" class="form-control" />
                        <span asp-validation-for="PlanName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Difficulty Level (1-5)</label>
                        <input asp-for="DifficultyLevel" type="number" min="1" max="5" class="form-control" />
                        <span asp-validation-for="DifficultyLevel" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Assign to Trainer</label>
                    <select asp-for="TrainerID" class="form-select border-info" asp-items="ViewBag.Trainers">
                        <option value="">-- Change Trainer --</option>
                    </select>
                    <span asp-validation-for="TrainerID" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-info text-white px-5 shadow-sm">Update Plan</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>