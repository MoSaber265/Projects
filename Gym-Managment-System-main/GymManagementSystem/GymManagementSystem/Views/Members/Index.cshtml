@model IEnumerable<GymManagementSystem.Models.Member>

@{
    ViewData["Title"] = "Gym Members";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold">
            <i class="bi bi-people-fill"></i> Gym Members List
        </h1>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Register New Member
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Full Name</th>
                            <th>Email Address</th>
                            <th>Phone Number</th>
                            <th>Join Date</th>
                            <th>Membership</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@item.Name</td>
                                    <td>@item.Email</td>
                                    <td>
                                        <span class="text-muted"><i class="bi bi-telephone me-1"></i></span>
                                    @item.Phone
                                    </td>
                                    <td>@item.JoinDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                    @if (item.Membership != null)
                                    {
                                        @* تم تعديل MembershipType إلى Type *@
                                                <span class="badge bg-info text-dark">@item.Membership.Type</span>
                                    }
                                    else
                                    {
                                                <span class="badge bg-secondary">No Plan</span>
                                    }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.MemberID" class="btn btn-sm btn-outline-warning" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.MemberID" class="btn btn-sm btn-outline-info" title="Details">
                                                <i class="bi bi-info-circle"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MemberID" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>