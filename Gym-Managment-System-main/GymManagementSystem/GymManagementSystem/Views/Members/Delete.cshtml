@model GymManagementSystem.Models.Member

@{
    ViewData["Title"] = "Delete Member";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-person-x-fill me-2"></i>Delete Member?</h4>
        </div>
        <div class="card-body">
            <p class="text-muted">Are you sure you want to delete this member? This action cannot be undone.</p>
            <hr />
            <dl class="row">
                <dt class="col-sm-3 text-muted">Full Name</dt>
                <dd class="col-sm-9 fw-bold">@Model.Name</dd>

                <dt class="col-sm-3 text-muted">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                @* السطور اللي كانت عاملة المشكلة (تم تصحيح s) *@
                <dt class="col-sm-3 text-muted">Membership Plan</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info text-dark">
                        @(Model.Membership?.Type ?? "No Plan Assigned")
                    </span>
                </dd>

                <dt class="col-sm-3 text-muted">Join Date</dt>
                <dd class="col-sm-9">@Model.JoinDate.ToShortDateString()</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="MemberID" />
                <div class="mt-4">
                    <button type="submit" class="btn btn-danger px-4 shadow-sm">Confirm Delete</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>