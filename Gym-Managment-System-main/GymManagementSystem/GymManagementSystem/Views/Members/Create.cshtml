@model GymManagementSystem.Models.Member

@{
    ViewData["Title"] = "Add New Member";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Add New Member</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold mb-1">Full Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Mohamed Ahmed" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Email" class="control-label fw-bold mb-1">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="MembershipID" class="control-label fw-bold mb-1">Membership Plan</label>
                        @* تم التعديل هنا لـ MembershipID والـ List الصحيحة *@
                        <select asp-for="MembershipID" class="form-select" asp-items="ViewBag.MembershipList">
                            <option value="">-- Choose a Plan --</option>
                        </select>
                        <span asp-validation-for="MembershipID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="JoinDate" class="control-label fw-bold mb-1">Join Date</label>
                        <input asp-for="JoinDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        <i class="bi bi-save me-1"></i> Save Member
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}