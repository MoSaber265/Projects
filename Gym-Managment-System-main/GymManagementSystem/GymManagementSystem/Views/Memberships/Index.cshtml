@model IEnumerable<GymManagementSystem.Models.Membership>

@{
    ViewData["Title"] = "Membership Plans";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-card-checklist me-2 text-warning"></i> Membership Plans
            </h5>
            <a asp-action="Create" class="btn btn-warning btn-sm fw-bold">
                <i class="bi bi-plus-lg"></i> Add New Plan
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Plan Type</th>
                            <th>Duration</th>
                            <th>Price</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@item.Type</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-3">
                                            <i class="bi bi-clock-history me-1"></i> @item.Duration Days
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-success fw-bold">
                                        @item.Price.ToString("N2") <small class="text-muted">EGP</small>
                                        </span>
                                    </td>
                                    <td class="text-center pe-3">
                                        <div class="btn-group shadow-sm border rounded" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.MemberShip" 
                                               class="btn btn-white btn-sm text-warning border-end" title="Edit">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.MemberShip" 
                                               class="btn btn-white btn-sm text-info border-end" title="Details">
                                                <i class="bi bi-info-circle fs-5"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MemberShip" 
                                               class="btn btn-white btn-sm text-danger" title="Delete">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white text-muted small py-2">
            Total Membership Types: @Model.Count()
        </div>
    </div>
</div>