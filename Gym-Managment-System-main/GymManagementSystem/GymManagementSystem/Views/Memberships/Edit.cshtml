@model GymManagementSystem.Models.Membership

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0"><i class="bi bi-gear-fill"></i> Update Membership Plan</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                @* تأكد إن الـ Hidden field مربوط بالـ ID الصح *@
                <input type="hidden" asp-for="MemberShip" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Plan Type</label>
                        <input asp-for="Type" class="form-control" placeholder="e.g. Gold, Silver, Monthly" />
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Price ($)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Duration (Months/Days Description)</label>
                    <input asp-for="Duration" class="form-control" placeholder="e.g. 1 Month" />
                    <span asp-validation-for="Duration" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success px-4">Update Plan</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>