@model GymManagementSystem.Models.Membership

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4>Delete Membership Plan?</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Plan Type</dt>
                <dd class="col-sm-9">@Model.Type</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@Model.Duration Days/Months</dd>

                <dt class="col-sm-3">Price</dt>
                <dd class="col-sm-9">@Model.Price.ToString("F2")</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="MemberShip" />
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>