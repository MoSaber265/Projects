@model IEnumerable<GymManagementSystem.Models.Trainer>

@{
    ViewData["Title"] = "Trainers Management";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h2 class="text-dark fw-bold mb-0">
                <i class="bi bi-people-fill text-primary me-2"></i> Trainers List
            </h2>
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> Add New Trainer
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Trainer Name</th>
                            <th>Specialization</th>
                            <th>Phone</th>
                            <th>Salary</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3 bg-light rounded-circle text-center p-2">
                                                <i class="bi bi-person text-secondary"></i>
                                            </div>
                                            <span class="fw-bold">@item.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">@item.Specialization</span>
                                    </td>
                                    <td>
                                        <i class="bi bi-telephone text-muted me-1"></i> @item.Phone
                                    </td>
                                    <td class="fw-bold text-success">
                                    @item.Salary.ToString("C0") @* عرض الراتب كعملة بدون قروش *@
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                        @* زرار الحذف اللي بيوديك لصفحة التأكيد اللي عملناها *@
                                            <a asp-action="Delete" asp-route-id="@item.TrainerID" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (!Model.Any())
        {
                <div class="card-footer bg-light text-center py-5">
                    <i class="bi bi-person-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted">No trainers found. Start by adding one!</p>
                </div>
        }
    </div>
</div>