@model IEnumerable<GymManagementSystem.Models.Trainer>

@{
    ViewData["Title"] = "Trainers Management";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-people-fill text-warning me-2"></i> Trainers List
            </h5>
            <a asp-action="Create" class="btn btn-warning btn-sm fw-bold shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> Add New Trainer
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Trainer Name</th>
                            <th>Specialization</th>
                            <th>Phone</th>
                            <th>Salary</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                <i class="bi bi-person-badge-fill fs-5"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@item.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-3">
                                        @item.Specialization
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted small">
                                            <i class="bi bi-telephone-fill me-1"></i> @item.Phone
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success">
                                        @item.Salary.ToString("N0") <small class="text-muted">EGP</small>
                                        </span>
                                    </td>
                                    <td class="text-center pe-3">
                                        <div class="btn-group shadow-sm border rounded" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.TrainerID" 
                                               class="btn btn-white btn-sm text-warning border-end" title="Edit Trainer">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.TrainerID" 
                                               class="btn btn-white btn-sm text-info border-end" title="View Details">
                                                <i class="bi bi-info-circle fs-5"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.TrainerID" 
                                               class="btn btn-white btn-sm text-danger" title="Remove Trainer">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
                <div class="card-footer bg-light text-center py-5 border-0">
                    <i class="bi bi-person-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted mb-0">No trainers found. Start by adding a new trainer to the system.</p>
                </div>
        }
        else
        {
                <div class="card-footer bg-white py-2 text-muted small">
                    Total Staff: @Model.Count() Trainers
                </div>
        }
    </div>
</div>