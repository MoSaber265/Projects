@model GymManagementSystem.Models.Trainer

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-person-gear"></i> Update Trainer Profile</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="TrainerID" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control border-dark" placeholder="Trainer Full Name" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-bold"></label>
                                <input asp-for="Phone" class="form-control border-dark" placeholder="01xxxxxxxxx" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Specialization" class="form-label fw-bold"></label>
                                <input asp-for="Specialization" class="form-control border-dark" placeholder="e.g. Yoga, MMA, Fitness" />
                                <span asp-validation-for="Specialization" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Salary" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark text-white">EGP</span>
                                    <input asp-for="Salary" class="form-control border-dark" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Salary" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-dark px-5 shadow-sm">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>