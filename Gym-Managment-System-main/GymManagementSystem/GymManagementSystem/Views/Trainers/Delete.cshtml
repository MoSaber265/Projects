@model GymManagementSystem.Models.Trainer

@{
    ViewData["Title"] = "Delete Trainer";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Trainer Removal</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning border-start border-4 border-warning">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Warning:</strong> Deleting this trainer will also affect their assigned work schedules and workout plans.
                    </div>

                    <dl class="row mt-4 mb-4">
                        <dt class="col-sm-4 text-muted">Full Name</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Name</dd>

                        <dt class="col-sm-4 text-muted">Phone Number</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4 text-muted">Specialization</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info text-dark">@Model.Specialization</span>
                        </dd>

                        <dt class="col-sm-4 text-muted">Salary</dt>
                        <dd class="col-sm-8 text-danger fw-bold fs-5">@Model.Salary.ToString("C2")</dd>
                    </dl>

                    <form asp-action="Delete">
                        @* الحقل المخفي للـ ID لضمان الحذف الصحيح *@
                        <input type="hidden" asp-for="TrainerID" />

                        <div class="border-top pt-3 d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-circle me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-4 shadow">
                                <i class="bi bi-trash-fill me-1"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>