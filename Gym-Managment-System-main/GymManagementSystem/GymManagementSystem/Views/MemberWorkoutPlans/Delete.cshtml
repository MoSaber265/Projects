@model GymManagementSystem.Models.MemberWorkoutPlan

@{
    ViewData["Title"] = "Delete Plan Assignment";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Are you sure you want to delete this assignment?</h4>
        </div>
        <div class="card-body">
            @if (Model != null)
            {
                    <dl class="row">
                        <dt class="col-sm-3">Member Name</dt>
                        <dd class="col-sm-9">@(Model.Member?.Name ?? "N/A")</dd>

                        <dt class="col-sm-3">Workout Plan</dt>
                        <dd class="col-sm-9">@(Model.WorkoutPlan?.PlanName ?? "N/A")</dd>

                        <dt class="col-sm-3">Start Date</dt>
                        <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
                    </dl>

                    <form asp-action="Delete">
                    @* تأكد أن هذا الحقل يطابق الخاصية Id في الموديل *@
                        <input type="hidden" asp-for="Id" /> 

                        <div class="mt-3">
                            <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                        </div>
                    </form>
            }
            else
            {
                    <div class="alert alert-warning">Assignment not found or already deleted.</div>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            }
        </div>
    </div>
</div>