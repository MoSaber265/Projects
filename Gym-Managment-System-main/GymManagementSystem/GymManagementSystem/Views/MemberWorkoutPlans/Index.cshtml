@model IEnumerable<GymManagementSystem.Models.MemberWorkoutPlan>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold"><i class="bi bi-person-gear"></i> Member Assignments</h2>
        <a asp-action="Create" class="btn btn-success shadow">
            <i class="bi bi-plus-circle"></i> Assign Plan to Member
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered shadow-sm bg-white">
            <thead class="table-success">
                <tr>
                    <th>Member Name</th>
                    <th>Workout Plan</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th class="text-center">Actions</th> @* عمود الأكشن *@
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                        <tr>
                            <td><strong>@item.Member?.Name</strong></td>
                            <td><span class="badge bg-primary">@item.WorkoutPlan?.PlanName</span></td>
                            <td>@item.StartDate.ToShortDateString()</td>
                            <td>@(item.EndDate?.ToShortDateString() ?? "Ongoing")</td>
                            <td class="text-center">
                            @* زرار الحذف اللي هينادي على أكشن الـ Delete *@
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm shadow-sm">
                                    <i class="bi bi-trash-fill"></i> Remove
                                </a>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>