@model GymManagementSystem.Models.MemberWorkoutPlan

@{
    ViewData["Title"] = "Assign Plan";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill"></i> Assign Workout Plan to Member</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="MemberID" class="form-label fw-bold">Select Member</label>
                            @* تأكد أن ViewBag.Members مبعوث من الكنترولر *@
                            <select asp-for="MemberID" class="form-select shadow-sm" asp-items="ViewBag.Members">
                                <option value="">-- Choose Member --</option>
                            </select>
                            <span asp-validation-for="MemberID" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PlanID" class="form-label fw-bold">Select Workout Plan</label>
                            @* تأكد أن ViewBag.Plans مبعوث من الكنترولر *@
                            <select asp-for="PlanID" class="form-select shadow-sm" asp-items="ViewBag.Plans">
                                <option value="">-- Choose Plan --</option>
                            </select>
                            <span asp-validation-for="PlanID" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                                @* الـ value هنا مهمة عشان يفتح على تاريخ النهاردة تلقائي *@
                                <input asp-for="StartDate" type="date" class="form-control shadow-sm" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold">End Date (Optional)</label>
                                <input asp-for="EndDate" type="date" class="form-control shadow-sm" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary px-5 shadow">
                                <i class="bi bi-check-circle"></i> Assign Plan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}