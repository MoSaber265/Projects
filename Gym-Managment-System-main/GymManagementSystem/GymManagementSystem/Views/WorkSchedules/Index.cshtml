@model IEnumerable<GymManagementSystem.Models.WorkSchedule>

@{
    ViewData["Title"] = "Gym Schedule";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold mb-0">
            <i class="bi bi-calendar3 text-danger me-2"></i>Gym Work Schedule
        </h2>
        <a asp-action="Create" class="btn btn-danger shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Add New Shift
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Day & Date</th>
                            <th>Coach</th>
                            <th>Workout Plan</th>
                            <th>Hall</th>
                            <th>Time Slot</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            // حركة صايعة: لو التاريخ النهاردة، نخلي الصف بلون مختلف
                            var rowClass = item.ScheduleDate.Date == DateTime.Today ? "table-warning" : "";

                                <tr class="@rowClass">
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.ScheduleDate.ToString("dddd")</div>
                                        <small class="text-muted">@item.ScheduleDate.ToShortDateString()</small>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle text-secondary me-2"></i>
                                            <strong>@item.Trainer?.Name</strong>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark shadow-sm">
                                            <i class="bi bi-clipboard2-pulse me-1"></i> @(item.WorkoutPlan?.PlanName ?? "General")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">Hall @item.Hall</span>
                                    </td>
                                    <td>
                                        <div class="text-nowrap">
                                            <i class="bi bi-clock me-1 text-danger"></i>
                                        @DateTime.Today.Add(item.StartTime).ToString("hh:mm tt") 
                                            <span class="mx-1">-</span>
                                        @DateTime.Today.Add(item.EndTime).ToString("hh:mm tt")
                                        </div>
                                    </td>
                                    <td class="text-center ps-0">
                                        <a asp-action="Delete" asp-route-id="@item.ScheduleID" class="btn btn-sm btn-outline-danger border-0">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
                <div class="card-footer bg-white text-center py-5">
                    <i class="bi bi-calendar-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted">No shifts scheduled for this period.</p>
                </div>
        }
    </div>
</div>