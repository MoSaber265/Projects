@model IEnumerable<GymManagementSystem.Models.WorkSchedule>

@{
    ViewData["Title"] = "Gym Schedule";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-calendar3 text-danger me-2"></i> Gym Work Schedule
            </h5>
            <a asp-action="Create" class="btn btn-danger btn-sm fw-bold shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Add New Shift
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Day & Date</th>
                            <th>Coach</th>
                            <th>Workout Plan</th>
                            <th>Hall</th>
                            <th>Time Slot</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            // تم الإبقاء على حركتك الصايعة لتمييز يومنا الحالي
                            var rowClass = item.ScheduleDate.Date == DateTime.Today ? "table-warning" : "";

                                <tr class="@rowClass">
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.ScheduleDate.ToString("dddd")</div>
                                        <span class="badge bg-light text-muted border px-2">@item.ScheduleDate.ToShortDateString()</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-danger-subtle text-danger rounded-circle p-1 me-2" style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="fw-bold">@item.Trainer?.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-3">
                                            <i class="bi bi-clipboard2-pulse me-1"></i> @(item.WorkoutPlan?.PlanName ?? "General")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary px-2">
                                            <i class="bi bi-door-open me-1"></i> Hall @item.Hall
                                        </span>
                                    </td>
                                    <td>
                                        <div class="text-nowrap small fw-bold">
                                            <i class="bi bi-clock text-danger me-1"></i>
                                        @DateTime.Today.Add(item.StartTime).ToString("hh:mm tt") 
                                            <span class="text-muted mx-1">→</span>
                                        @DateTime.Today.Add(item.EndTime).ToString("hh:mm tt")
                                        </div>
                                    </td>
                                    <td class="text-center pe-3">
                                        <div class="btn-group shadow-sm border rounded" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.ScheduleID" 
                                               class="btn btn-white btn-sm text-warning border-end" title="Edit Shift">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.ScheduleID" 
                                               class="btn btn-white btn-sm text-info border-end" title="View Details">
                                                <i class="bi bi-info-circle fs-5"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.ScheduleID" 
                                               class="btn btn-white btn-sm text-danger" title="Cancel Shift">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
                <div class="card-footer bg-light text-center py-5 border-0">
                    <i class="bi bi-calendar-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted mb-0">No shifts scheduled. Click 'Add New Shift' to populate the calendar.</p>
                </div>
        }
        else
        {
                <div class="card-footer bg-white py-2 text-muted small text-end">
                    Total Scheduled Shifts: @Model.Count()
                </div>
        }
    </div>
</div>