@model GymManagementSystem.Models.WorkSchedule

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-calendar3"></i> Update Session Schedule</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ScheduleID" />

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="ScheduleDate" class="form-label fw-bold"></label>
                                <input asp-for="ScheduleDate" class="form-control border-primary" type="date" />
                                <span asp-validation-for="ScheduleDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Hall" class="form-label fw-bold"></label>
                                <input asp-for="Hall" class="form-control border-primary" placeholder="Hall 1-20" />
                                <span asp-validation-for="Hall" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Assign Trainer</label>
                                <select asp-for="TrainerID" class="form-select border-primary" asp-items="ViewBag.Trainers"></select>
                                <span asp-validation-for="TrainerID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-3 mb-3">
                                <label asp-for="StartTime" class="form-label fw-bold"></label>
                                <input asp-for="StartTime" class="form-control border-primary" type="time" />
                                <span asp-validation-for="StartTime" class="text-danger"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="EndTime" class="form-label fw-bold"></label>
                                <input asp-for="EndTime" class="form-control border-primary" type="time" />
                                <span asp-validation-for="EndTime" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Workout Plan</label>
                                <select asp-for="PlanID" class="form-select border-primary" asp-items="ViewBag.Plans"></select>
                                <span asp-validation-for="PlanID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 shadow">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>