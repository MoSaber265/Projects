@model GymManagementSystem.Models.WorkSchedule

@{
    ViewData["Title"] = "Delete Schedule";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-calendar-x me-2"></i>Confirm Schedule Deletion</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Are you sure you want to remove this session from the gym calendar?</p>

                    <div class="bg-light p-3 rounded mb-4 border-start border-4 border-danger">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Scheduled Date</dt>
                            <dd class="col-sm-8 fw-bold text-dark">
                                <i class="bi bi-calendar3 me-2 text-danger"></i>@Model.ScheduleDate.ToString("dddd, dd MMMM yyyy")
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">Coach</dt>
                            <dd class="col-sm-8 mt-2">
                                <span class="badge bg-primary text-white p-2">
                                    <i class="bi bi-person-fill me-1"></i>@(Model.Trainer?.Name ?? "No coach assigned")
                                </span>
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">Training Plan</dt>
                            <dd class="col-sm-8 mt-2 text-info fw-bold">
                                <i class="bi bi-clipboard-check me-2"></i>@(Model.WorkoutPlan?.PlanName ?? "General Session")
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">Time Slot</dt>
                            <dd class="col-sm-8 mt-2">
                                <i class="bi bi-clock-fill me-2 text-warning"></i>
                                @DateTime.Today.Add(Model.StartTime).ToString("hh:mm tt") 
                                <span class="text-muted px-1">to</span> 
                                @DateTime.Today.Add(Model.EndTime).ToString("hh:mm tt")
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">Location</dt>
                            <dd class="col-sm-8 mt-2">
                                <span class="badge bg-secondary">Hall #@Model.Hall</span>
                            </dd>
                        </dl>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ScheduleID" />

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Keep Session
                            </a>
                            <button type="submit" class="btn btn-danger shadow-sm px-4">
                                <i class="bi bi-trash3-fill me-1"></i> Delete Forever
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>