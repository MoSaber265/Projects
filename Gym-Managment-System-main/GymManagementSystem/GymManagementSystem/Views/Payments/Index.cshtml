@model IEnumerable<GymManagementSystem.Models.Payment>

@{
    ViewData["Title"] = "Payments Records";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-cash-stack me-2 text-warning"></i> Payments Records
            </h5>
            <a asp-action="Create" class="btn btn-warning btn-sm fw-bold shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> New Payment
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Member Name</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Date</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-secondary-subtle text-secondary rounded-circle p-2 me-2" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@(item.Member?.Name ?? "N/A")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-success-subtle text-success fs-6 border border-success-subtle px-3">
                                        @item.Amount.ToString("N2") <small>EGP</small>
                                        </span>
                                    </td>
                                    <td>
                                    @{
                                        var badgeClass = item.PaymentMethod switch
                                        {
                                            "Cash" => "bg-info-subtle text-info-emphasis border-info-subtle",
                                            "Visa/Credit" => "bg-primary-subtle text-primary-emphasis border-primary-subtle",
                                            "Vodafone Cash" => "bg-danger-subtle text-danger-emphasis border-danger-subtle",
                                            _ => "bg-light text-dark border-secondary-subtle"
                                        };
                                    }
                                        <span class="badge border @badgeClass px-2">
                                            <i class="bi bi-credit-card-2-back me-1"></i> @item.PaymentMethod
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted small">
                                            <i class="bi bi-calendar-check me-1"></i> @item.PaymentDate.ToString("dd MMM yyyy")
                                        </span>
                                    </td>
                                    <td class="text-center pe-3">
                                        <div class="btn-group shadow-sm border rounded" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.PaymentID" 
                                               class="btn btn-white btn-sm text-warning border-end" title="Edit Record">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.PaymentID" 
                                               class="btn btn-white btn-sm text-info border-end" title="Receipt Details">
                                                <i class="bi bi-file-earmark-text fs-5"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.PaymentID" 
                                               class="btn btn-white btn-sm text-danger" title="Void Payment">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3">
            @if (!Model.Any())
            {
                    <div class="text-center py-4">
                        <i class="bi bi-folder-x fs-1 text-muted"></i>
                        <p class="text-muted mt-2">No payment records found for this period.</p>
                    </div>
            }
            else
            {
                    <div class="row align-items-center">
                        <div class="col text-muted small">
                            Showing @Model.Count() total transactions
                        </div>
                        <div class="col text-end fw-bold text-success">
                            Total: @Model.Sum(x => x.Amount).ToString("N2") EGP
                        </div>
                    </div>
            }
        </div>
    </div>
</div>